#!/usr/bin/env bash
set -e
set -u

if command -v clip.exe &>/dev/null; then
  exec clip.exe
elif command -v pbcopy &>/dev/null; then
  exec pbcopy
elif command -v xclip &>/dev/null; then
  exec xclip -selection clipboard
elif command -v putclip &>/dev/null; then
  exec putclip
else
  rm -f /tmp/clipboard 2> /dev/null
  if [ $# -eq 0 ]; then
    cat > /tmp/clipboard
  else
    cat "$1" > /tmp/clipboard
  fi
fi
